#!/usr/bin/env bash
# BMO helper: recordatorios y temporizadores locales (systemd-run --user).
#   bmo-reminder en 10 minutos revisar el horno
#   bmo-reminder en 2 horas llamar a mamá
#   bmo-reminder a las 15:30 reunión
#   bmo-reminder lista
#   bmo-reminder cancelar <unidad|todo>
# Al cumplirse: notificación de escritorio + BMO lo dice por voz (POST /bot_message).
set -u

SELF="$(readlink -f "$0")"

case "${1:-}" in
  _fire)
    # Invocado por el timer transitorio cuando se cumple el plazo.
    shift
    TEXT="${*:-recordatorio}"
    notify-send -u critical "⏰ BMO Recordatorio" "$TEXT" 2>/dev/null || true
    python3 - "$TEXT" <<'EOF'
import json, sys, urllib.request
req = urllib.request.Request(
    'http://127.0.0.1:8765/bot_message',
    data=json.dumps({'text': f'Recordatorio: {sys.argv[1]}'}).encode(),
    headers={'Content-Type': 'application/json'})
try:
    urllib.request.urlopen(req, timeout=5)
except Exception:
    pass  # BMO apagado: queda la notificación de escritorio
EOF
    ;;

  en)
    shift
    N="${1:-}"; UNIDAD="${2:-}"; shift 2 2>/dev/null || { echo "uso: bmo-reminder en <N> <minutos|horas> <texto>"; exit 1; }
    TEXT="${*:-}"
    [[ "$N" =~ ^[0-9]+$ ]] || { echo "uso: bmo-reminder en <N> <minutos|horas> <texto>"; exit 1; }
    case "$UNIDAD" in
      segundo*) SECS=$N; HUM="$N segundos" ;;
      minuto*)  SECS=$((N * 60)); HUM="$N minutos" ;;
      hora*)    SECS=$((N * 3600)); HUM="$N horas" ;;
      *)        TEXT="$UNIDAD ${TEXT}"; SECS=$((N * 60)); HUM="$N minutos" ;;
    esac
    [ -n "$TEXT" ] || { echo "Falta el texto del recordatorio"; exit 1; }
    UNIT="bmo-rem-$(date +%s%N | cut -c6-16)"
    systemd-run --user --quiet --on-active="$SECS" --unit="$UNIT" \
      --description="$TEXT" "$SELF" _fire "$TEXT" \
      && echo "Listo: te recuerdo '$TEXT' en $HUM" \
      || { echo "ERROR: no pude programar el recordatorio"; exit 1; }
    ;;

  a|alas)
    shift
    [ "${1:-}" = "las" ] && shift
    HHMM="${1:-}"; shift 2>/dev/null || true
    TEXT="${*:-}"
    [[ "$HHMM" =~ ^([01]?[0-9]|2[0-3]):[0-5][0-9]$ ]] || { echo "uso: bmo-reminder a las HH:MM <texto>"; exit 1; }
    [ -n "$TEXT" ] || { echo "Falta el texto del recordatorio"; exit 1; }
    # Si la hora ya pasó hoy, se agenda para mañana.
    WHEN=$(python3 -c "
import datetime
h, m = map(int, '$HHMM'.split(':'))
t = datetime.datetime.now().replace(hour=h, minute=m, second=0, microsecond=0)
if t <= datetime.datetime.now(): t += datetime.timedelta(days=1)
print(t.strftime('%Y-%m-%d %H:%M:%S'))")
    UNIT="bmo-rem-$(date +%s%N | cut -c6-16)"
    systemd-run --user --quiet --on-calendar="$WHEN" --unit="$UNIT" \
      --description="$TEXT" "$SELF" _fire "$TEXT" \
      && echo "Listo: te recuerdo '$TEXT' a las $HHMM (${WHEN%% *})" \
      || { echo "ERROR: no pude programar el recordatorio"; exit 1; }
    ;;

  lista|list)
    out=$(systemctl --user list-timers 'bmo-rem-*' --no-legend --output=json 2>/dev/null \
      | python3 -c "
import datetime, json, subprocess, sys
timers = json.load(sys.stdin)
for t in timers:
    unit = t['unit']
    desc = subprocess.run(['systemctl', '--user', 'show', '-p', 'Description',
                           '--value', unit], capture_output=True, text=True).stdout.strip()
    when = t.get('next')
    hhmm = (datetime.datetime.fromtimestamp(when / 1e6).strftime('%H:%M del %d/%m')
            if when else '?')
    print(f\"- '{desc}' a las {hhmm}  [{unit}]\")
" 2>/dev/null)
    [ -n "$out" ] && echo "$out" || echo "No hay recordatorios pendientes"
    ;;

  cancelar|cancel)
    TARGET="${2:-todo}"
    if [ "$TARGET" = "todo" ] || [ "$TARGET" = "todos" ]; then
      n=0
      while read -r unit; do
        [ -n "$unit" ] || continue
        systemctl --user stop "$unit" 2>/dev/null && n=$((n + 1))
      done < <(systemctl --user list-timers 'bmo-rem-*' --no-legend --output=json 2>/dev/null \
               | python3 -c "import json,sys; [print(t['unit']) for t in json.load(sys.stdin)]" 2>/dev/null)
      echo "Cancelados $n recordatorios"
    else
      systemctl --user stop "$TARGET" 2>/dev/null && echo "Cancelado $TARGET" || echo "No encontré $TARGET"
    fi
    ;;

  *)
    echo "uso: bmo-reminder {en <N> <minutos|horas> <texto> | a las HH:MM <texto> | lista | cancelar [unidad|todo]}"
    exit 1
    ;;
esac
