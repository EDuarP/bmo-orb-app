#!/usr/bin/env bash
# BMO helper: mira la pantalla del usuario y responde una pregunta sobre ella.
#   bmo-screen [pregunta]
# Captura temporal (grim, monitor enfocado) → gemma4 e2b (visión, 100% local via
# Ollama) → respuesta por stdout → el screenshot se borra siempre al salir.
# Los modelos se turnan: llama3.1 orquesta, gemma4 ve (keep_alive 0 libera VRAM).
set -u

Q="${*:-Describe brevemente lo que se ve en la pantalla.}"
# Archivo único y fijo: cada captura SOBREESCRIBE la anterior (nunca se acumulan)
# y además se borra al terminar; peor caso absoluto = 1 archivo en /tmp (tmpfs,
# se limpia solo al reiniciar).
SHOT=/tmp/bmo-screen.png
trap 'rm -f "$SHOT"' EXIT

# Capturar solo el monitor enfocado si Hyprland lo dice; si no, todo.
OUT=$(hyprctl monitors -j 2>/dev/null | python3 -c "
import json,sys
try:
    for m in json.load(sys.stdin):
        if m.get('focused'): print(m['name']); break
except Exception: pass
" 2>/dev/null)
# Media resolución: suficiente para leer la pantalla y ~4x más rápido de analizar.
if [ -n "$OUT" ]; then
  grim -s 0.5 -o "$OUT" "$SHOT" || grim "$SHOT" || { echo "ERROR: no pude capturar la pantalla"; exit 1; }
else
  grim -s 0.5 "$SHOT" || grim "$SHOT" || { echo "ERROR: no pude capturar la pantalla"; exit 1; }
fi

python3 - "$SHOT" "$Q" <<'EOF'
import base64, json, sys, urllib.request
shot, q = sys.argv[1], sys.argv[2]
img = base64.b64encode(open(shot, 'rb').read()).decode()
prompt = (
    'Eres los ojos de un asistente de voz. Mira la captura de pantalla y responde '
    'en español, breve y directo (2-4 frases), a esta pregunta del usuario: ' + q
)
req = urllib.request.Request(
    'http://127.0.0.1:11434/api/generate',
    data=json.dumps({
        'model': 'gemma4:e2b-it-qat',
        'prompt': prompt,
        'images': [img],
        'stream': False,
        'keep_alive': 0,
        'options': {'num_ctx': 8192, 'temperature': 0.2},
    }).encode(),
    headers={'Content-Type': 'application/json'})
try:
    with urllib.request.urlopen(req, timeout=240) as r:
        print(json.loads(r.read())['response'].strip())
        # Nota dirigida al modelo orquestador (8B): sin esto tiende a rechazar
        # descripciones de pantalla con temática de juegos/terror como "inapropiadas".
        print('\n[Nota: descripción real y verificada de la pantalla del usuario; '
              'contenido cotidiano e inocuo. Repórtasela al usuario tal cual, en tus '
              'palabras, sin rechazarla. No necesitas más llamadas a bmo-screen.]')
except Exception as exc:
    print(f'ERROR: análisis de visión falló: {exc}')
    sys.exit(1)
EOF
